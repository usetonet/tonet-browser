---
import Footer from "../components/Footer.astro";
import SiteNav from "../components/SiteNav";
import type { SitePage } from "../types/site-page";
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  page: SitePage;
}

const { title, description, page } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <title>{title}</title>
    <link rel="icon" href="/tonet.svg" type="image/svg+xml" />
    <slot name="head" />
  </head>
  <body
    class="min-h-screen bg-[#070a10] bg-[radial-gradient(1200px_600px_at_10%_-10%,rgba(79,140,255,0.18),transparent),radial-gradient(900px_500px_at_90%_0%,rgba(124,92,255,0.15),transparent)] font-sans text-[#e8ecf4] antialiased"
    data-page={page}
  >
    <SiteNav current={page} client:load />
    <slot />
    <Footer />
  </body>
</html>
