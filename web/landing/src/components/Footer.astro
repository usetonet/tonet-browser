<footer
  class="border-t border-white/[0.08] px-6 py-10 pb-12 text-center text-[0.9rem] text-[#9aa3b5]"
>
  <p class="mb-4 flex flex-wrap items-center justify-center gap-2.5">
    <label id="lang-switcher-label" class="text-[0.85rem] text-[#9aa3b5]" for="site-lang">Site language</label>
    <select
      id="site-lang"
      name="site-lang"
      class="rounded-lg border border-white/[0.08] bg-white/[0.06] px-3 py-1.5 font-inherit text-[0.85rem] text-[#e8ecf4]"
      aria-describedby="lang-switcher-label"
    >
      <option value="auto">Auto (browser)</option>
      <option value="en">English</option>
      <option value="es">Español</option>
      <option value="de">Deutsch</option>
      <option value="fr">Français</option>
    </select>
  </p>
  <p>
    <strong class="text-[#e8ecf4]">usetonet.com</strong> — <span id="footer-line1-prefix">project</span>
    <a class="text-[#4f8cff] hover:underline" href="https://github.com/usetonet/tonet-browser">usetonet/tonet-browser</a>
  </p>
  <p id="footer-line2" class="mt-1">
    Landing on Cloudflare Workers · Servo-based Tonet browser under active development
  </p>
</footer>
