---
import BaseLayout from "../layouts/BaseLayout.astro";
import { LanguageBoot } from "../components/LanguageBoot";
---

<BaseLayout title="Compare Browsers — Tonet" description="Tonet vs Chrome, Brave, Firefox — factual comparison table." page="compare">
  <div class="compare-wrap">
    <h1 class="mb-2 text-4xl">Tonet vs mainstream browsers</h1>
    <p class="compare-lead">
      Tonet is intentionally narrow in scope: a transparent, policy-driven surface built on the <strong>Servo</strong> engine with a custom shell. This page summarizes <strong>documented product facts</strong> today — not benchmark winners — so teams can decide fit quickly.
    </p>

    <article class="card mb-5">
      <h2 class="mt-0">Legend</h2>
      <p class="lead mb-0">
        <span class="ck ck-yes" aria-label="yes">✓</span> strong / typical,
        <span class="ck ck-part" aria-label="partial">◐</span> partial or roadmap,
        <span class="ck ck-no" aria-label="no">○</span> not a focus (not necessarily “bad”).
      </p>
    </article>

    <article class="card mb-6">
      <h2 class="mt-0">Positioning</h2>
      <p class="m-0 leading-relaxed text-[#9aa3b5]">
        Chrome and Brave optimize for broad compatibility and massive ecosystem depth. Tonet optimizes for product teams and advanced users who need a controlled browser
        surface with clear internals and deterministic packaging.
      </p>
    </article>

    <h2 class="compare-subhead">Product dimensions</h2>
    <div class="compare-table-wrap">
      <table class="compare-table" aria-label="Browser comparison by dimension">
        <thead>
          <tr>
            <th scope="col">Dimension</th>
            <th scope="col">Tonet</th>
            <th scope="col">Google Chrome</th>
            <th scope="col">Brave</th>
            <th scope="col">Mozilla Firefox</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td>Rendering engine (core)</td>
            <td>Servo (in-process for pages); custom shell — not Blink/WebKit/CEF.</td>
            <td>Blink (Chromium).</td>
            <td>Blink (Chromium).</td>
            <td>Gecko + SpiderMonkey.</td>
          </tr>
          <tr>
            <td>Primary distribution model</td>
            <td>Self-hosted CDN manifest (<code class="rounded bg-white/[0.06] px-1">version.json</code>) + GitHub releases artifacts.</td>
            <td>Google update infra + OEM bundles.</td>
            <td>Brave update channels.</td>
            <td>Mozilla + distro packages.</td>
          </tr>
          <tr>
            <td>Open-source license (browser)</td>
            <td>GPL-3.0-or-later (repository).</td>
            <td>Chromium BSD-style + proprietary Chrome additions.</td>
            <td>MPL/Chromium mix; Brave-owned services.</td>
            <td>MPL 2.0.</td>
          </tr>
          <tr>
            <td>Default web compatibility target</td>
            <td>MVP reading/search stack; strict page-size policy (e.g. 1 MB guard).</td>
            <td>Full modern web.</td>
            <td>Full modern web + shields.</td>
            <td>Full modern web.</td>
          </tr>
          <tr>
            <td>Extension ecosystem</td>
            <td>Not a goal for MVP (no Web Store parity).</td>
            <td>Chrome Web Store.</td>
            <td>Chrome-compatible extensions.</td>
            <td>Firefox AMO + MV3 transition.</td>
          </tr>
          <tr>
            <td>Update check mechanism (Tonet app)</td>
            <td>Configurable manifest URL; no GitHub Releases API dependency at runtime.</td>
            <td>Google updater.</td>
            <td>Brave updater.</td>
            <td>Mozilla updater.</td>
          </tr>
          <tr>
            <td>Typical install size (order of magnitude)</td>
            <td>Single-digit ×10 MB binary + platform deps (Windows ANGLE DLLs alongside exe).</td>
            <td>Hundreds of MB installed.</td>
            <td>Similar to Chromium-class.</td>
            <td>Hundreds of MB installed.</td>
          </tr>
        </tbody>
      </table>
    </div>
    <p class="compare-note">
      Rows reflect architecture and delivery choices described in this repository as of the current milestone — not marketing claims or independent benchmarks. Refresh this
      table when major milestones ship (see <a class="text-[#4f8cff] hover:underline" href="/roadmap.html">Roadmap</a>).
    </p>

    <h2 class="compare-subhead">Feature matrix</h2>
    <div class="compare-table-wrap">
      <table class="compare-table" aria-label="Browser feature matrix">
        <thead>
          <tr>
            <th scope="col">Capability</th>
            <th scope="col">Tonet</th>
            <th scope="col">Chrome</th>
            <th scope="col">Brave</th>
            <th scope="col">Firefox</th>
            <th scope="col">Safari</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td class="feat">Broad web compatibility (full “Chrome-tier” surface)</td>
            <td><span class="ck ck-part" title="Growing via milestones">◐</span></td>
            <td><span class="ck ck-yes" title="Primary strength">✓</span></td>
            <td><span class="ck ck-yes" title="Chromium-class">✓</span></td>
            <td><span class="ck ck-yes" title="Strong overall">✓</span></td>
            <td><span class="ck ck-yes" title="Apple WebKit focus">✓</span></td>
          </tr>
          <tr>
            <td class="feat">Explicit lightweight / purity budgets</td>
            <td><span class="ck ck-yes" title="Core goal">✓</span></td>
            <td><span class="ck ck-no" title="Not the design center">○</span></td>
            <td><span class="ck ck-part" title="Shields + optional extras">◐</span></td>
            <td><span class="ck ck-part" title="Some controls">◐</span></td>
            <td><span class="ck ck-no" title="Not emphasized">○</span></td>
          </tr>
          <tr>
            <td class="feat">Built-in aggressive ad / tracker blocking (default-on)</td>
            <td><span class="ck ck-part" title="Policy + roadmap">◐</span></td>
            <td><span class="ck ck-no" title="Extensions ecosystem">○</span></td>
            <td><span class="ck ck-yes" title="Shields">✓</span></td>
            <td><span class="ck ck-part" title="ETP etc.">◐</span></td>
            <td><span class="ck ck-part" title="ITP etc.">◐</span></td>
          </tr>
          <tr>
            <td class="feat">Fully open-source engine stack (auditable end-to-end)</td>
            <td><span class="ck ck-yes" title="GPL project + visible pipeline">✓</span></td>
            <td><span class="ck ck-no" title="Chromium open; Chrome adds proprietary pieces">○</span></td>
            <td><span class="ck ck-part" title="Chromium base">◐</span></td>
            <td><span class="ck ck-yes" title="Gecko open">✓</span></td>
            <td><span class="ck ck-no" title="WebKit partly; Safari proprietary">○</span></td>
          </tr>
          <tr>
            <td class="feat">Operator-controlled CDN artifacts &amp; update manifest</td>
            <td><span class="ck ck-yes" title="First-class story">✓</span></td>
            <td><span class="ck ck-no" title="Google update infra">○</span></td>
            <td><span class="ck ck-no" title="Vendor-controlled">○</span></td>
            <td><span class="ck ck-no" title="Mozilla infra">○</span></td>
            <td><span class="ck ck-no" title="Apple infra">○</span></td>
          </tr>
          <tr>
            <td class="feat">Public roadmap &amp; engineering transparency</td>
            <td><span class="ck ck-yes" title="Published milestones">✓</span></td>
            <td><span class="ck ck-part" title="Some public signals">◐</span></td>
            <td><span class="ck ck-part" title="Open Chromium lineage">◐</span></td>
            <td><span class="ck ck-yes" title="Strong open culture">✓</span></td>
            <td><span class="ck ck-no" title="Mostly closed planning">○</span></td>
          </tr>
        </tbody>
      </table>
    </div>

    <article class="card mt-7">
      <h2 class="mt-0">When Tonet is a strong fit</h2>
      <ul class="leading-relaxed text-[#9aa3b5]">
        <li>You need audit-friendly internals and deterministic packaging over maximal site compatibility.</li>
        <li>You prefer CDN-owned artifacts and manifests over opaque auto-update channels.</li>
        <li>You accept MVP limits today in exchange for an explicit roadmap (<code class="rounded bg-white/[0.06] px-1">TONET_VISION.md</code>).</li>
      </ul>
    </article>
  </div>

  <p class="mx-auto max-w-[1120px] px-6 pb-10 text-center text-[#9aa3b5]">
    <a class="text-[#4f8cff] hover:underline" href="/docs.html">Explore full documentation</a>
    · <a class="text-[#4f8cff] hover:underline" href="/guide.html">Using Tonet</a>
  </p>
  <LanguageBoot client:load />
</BaseLayout>
