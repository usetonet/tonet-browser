<?xml version="1.0" encoding="UTF-8"?>
<!--
  Instalador MSI de Tonet (WiX Toolset 3.11+).
  Genera un paquete per-machine x64 con acceso directo en el menú Inicio
  y entrada en «Agregar o quitar programas», similar a otros navegadores.
-->
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <Product Id="*"
           Name="Tonet"
           Language="1033"
           Version="$(var.ProductVersion)"
           Manufacturer="usetonet.com"
           UpgradeCode="E7C8F9A0-1234-5678-9ABC-DEF012345678">
    <Package InstallerVersion="300"
             Compressed="yes"
             InstallScope="perMachine"
             Description="Tonet — navegador web minimalista"
             Comments="https://usetonet.com"
             Platform="x64" />

    <MajorUpgrade Schedule="afterInstallInitialize"
                  DowngradeErrorMessage="Una versión más nueva de Tonet ya está instalada." />

    <MediaTemplate EmbedCab="yes" />

    <Feature Id="MainFeature" Title="Tonet" Level="1" Absent="disallow"
             Description="Navegador Tonet y accesos directos">
      <ComponentGroupRef Id="TonetComponents" />
      <ComponentGroupRef Id="StartMenuCleanup" />
      <ComponentRef Id="CmpTonetDesktopShortcut" />
    </Feature>

    <!-- Interfaz gráfica: solo elegir carpeta (sin EULA obligatoria). -->
    <Property Id="WIXUI_INSTALLDIR" Value="INSTALLFOLDER" />
    <UIRef Id="WixUI_InstallDir" />
  </Product>

  <Fragment>
    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFiles64Folder">
        <Directory Id="INSTALLFOLDER" Name="Tonet" />
      </Directory>
      <!-- Menú Inicio «Todos los usuarios» (coherente con InstallScope perMachine). -->
      <Directory Id="CommonProgramMenuFolder">
        <Directory Id="ApplicationProgramsFolder" Name="Tonet" />
      </Directory>
      <!-- Escritorio «Todos los usuarios» (LGHT0094 si no se declara bajo TARGETDIR). -->
      <Directory Id="CommonDesktopFolder" />
    </Directory>
  </Fragment>

  <Fragment>
    <ComponentGroup Id="TonetComponents" Directory="INSTALLFOLDER">
      <Component Id="CmpTonetExe" Guid="B8C591D2-3456-7890-ABCD-EF1234567891" Win64="yes">
        <File Id="TonetEXE"
              Source="$(var.SourceDir)\tonet.exe"
              KeyPath="yes">
          <Shortcut Id="TonetStartMenuShortcut"
                    Name="Tonet"
                    Directory="ApplicationProgramsFolder"
                    WorkingDirectory="INSTALLFOLDER"
                    Description="Abrir el navegador Tonet"
                    Advertise="yes" />
        </File>
      </Component>
      <Component Id="CmpTonetLibEGL" Guid="B8C591D2-3456-7890-ABCD-EF1234567892" Win64="yes">
        <File Id="TonetLibEGL"
              Source="$(var.SourceDir)\libEGL.dll"
              KeyPath="yes" />
      </Component>
      <Component Id="CmpTonetLibGLESv2" Guid="B8C591D2-3456-7890-ABCD-EF1234567893" Win64="yes">
        <File Id="TonetLibGLESv2"
              Source="$(var.SourceDir)\libGLESv2.dll"
              KeyPath="yes" />
      </Component>
    </ComponentGroup>
  </Fragment>

  <Fragment>
    <!-- Acceso directo en el escritorio «Todos los usuarios». -->
    <DirectoryRef Id="CommonDesktopFolder">
      <Component Id="CmpTonetDesktopShortcut" Guid="A1B2C3D4-E5F6-4789-A012-3456789ABCDE" Win64="yes">
        <Shortcut Id="TonetDesktopShortcut"
                  Name="Tonet"
                  Target="[#TonetEXE]"
                  WorkingDirectory="INSTALLFOLDER"
                  Description="Abrir el navegador Tonet" />
        <RegistryValue Root="HKLM"
                       Key="SOFTWARE\usetonet\Tonet"
                       Name="DesktopShortcut"
                       Type="integer"
                       Value="1"
                       KeyPath="yes" />
      </Component>
    </DirectoryRef>
  </Fragment>

  <Fragment>
    <!-- Elimina la carpeta del menú Inicio al desinstalar (patrón WiX habitual). -->
    <ComponentGroup Id="StartMenuCleanup" Directory="ApplicationProgramsFolder">
      <Component Id="CmpStartMenuCleanup" Guid="C9D602E3-4567-8901-BCDE-F12345678902" Win64="yes">
        <RemoveFolder Id="RemoveApplicationProgramsFolder" On="uninstall" />
        <RegistryValue Root="HKLM"
                       Key="SOFTWARE\usetonet\Tonet"
                       Name="Installed"
                       Type="integer"
                       Value="1"
                       KeyPath="yes" />
      </Component>
    </ComponentGroup>
  </Fragment>
</Wix>
